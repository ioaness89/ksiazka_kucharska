<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ksiazka_kucharska.Views.FavoritesPage"
             Title="Ulubione przepisy">
    <CollectionView x:Name="FavoritesCollection">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="0,10" Padding="20">
                    <VerticalStackLayout>
                        <Label FontSize="20" Text="{Binding Title}" />
                        <Label FontSize="18" Text="{Binding Category}" />
                        <Label FontSize="15" Text="{Binding PreparationTimeMinutes, StringFormat='{}{0} min'}" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>